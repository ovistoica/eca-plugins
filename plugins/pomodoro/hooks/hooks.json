{
  "pomodoro-start": {
    "type": "chatStart",
    "visible": false,
    "actions": [
      {
        "type": "shell",
        "shell": "date +%s > /tmp/eca-pomodoro-start"
      }
    ]
  },
  "pomodoro-check": {
    "type": "postRequest",
    "visible": true,
    "actions": [
      {
        "type": "shell",
        "file": "pomodoro-check.sh"
      }
    ]
  }
}

{
  "allium.check-spec": {
    "type": "postToolCall",
    "matcher":
    {"eca__write_file": {"argsMatchers": { "path": [".*\\.allium$"]}},
     "eca__edit_file": {"argsMatchers": { "path": [".*\\.allium$"]}}},
    "visible": true,
    "actions": [
      {
        "type": "shell",
        "shell": "node \"${plugin:root}/hooks/check-spec.mjs\""
      }
    ]
  }
}

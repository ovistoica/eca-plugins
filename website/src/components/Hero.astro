---
interface Props {
  pluginCount: number;
}

const { pluginCount } = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-glow hero-glow--1"></div>
    <div class="hero-glow hero-glow--2"></div>
    <div class="hero-glow hero-glow--3"></div>
    <div class="hero-grid"></div>
  </div>
  <div class="hero-content container">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      {pluginCount} plugins available
    </div>
    <h1 class="hero-title">
      Extend ECA with
      <span class="hero-highlight">community plugins</span>
    </h1>
    <p class="hero-subtitle">
      Browse, discover, and install plugins that add skills, agents, rules, and more to your editor AI assistant.
    </p>
    <div class="hero-search">
      <svg class="hero-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <!-- Coupled: PluginGrid.astro reads #search-input for filtering -->
      <input
        type="text"
        id="search-input"
        class="hero-search-input"
        placeholder="Search plugins..."
        autocomplete="off"
        autofocus
      />
      <kbd class="hero-search-kbd">/</kbd>
    </div>
  </div>
  <div class="hero-fade"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 80px 0 56px;
  }

  /* Layered background like eca.dev hero */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      #007a94 0%,
      #006a82 30%,
      #005268 60%,
      var(--color-bg-primary) 100%
    );
    opacity: 0.35;
  }

  .hero-glow--1 {
    position: absolute;
    top: -20%;
    left: 30%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(0, 165, 184, 0.25) 0%, transparent 70%);
  }

  .hero-glow--2 {
    position: absolute;
    top: -10%;
    right: 10%;
    width: 40%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(0, 122, 148, 0.2) 0%, transparent 70%);
  }

  .hero-glow--3 {
    position: absolute;
    bottom: 0;
    left: 10%;
    width: 30%;
    height: 50%;
    background: radial-gradient(ellipse at center, rgba(0, 165, 184, 0.08) 0%, transparent 70%);
  }

  /* Subtle dot grid pattern */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 30%, black 20%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 30%, black 20%, transparent 80%);
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--color-bg-primary));
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 720px;
    animation: fadeIn 0.6s ease;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary-light);
    background: rgba(0, 165, 184, 0.08);
    border: 1px solid rgba(0, 165, 184, 0.2);
    padding: 6px 16px;
    border-radius: var(--radius-full);
    margin-bottom: 28px;
    backdrop-filter: blur(8px);
  }

  .hero-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-green);
    box-shadow: 0 0 8px var(--color-accent-green);
    animation: pulseGlow 3s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 18px;
    color: #fff;
  }

  .hero-highlight {
    background: linear-gradient(90deg, #00a5b8, var(--color-primary-hover));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 540px;
    margin: 0 auto 36px;
    line-height: 1.65;
  }

  .hero-search {
    position: relative;
    max-width: 500px;
    margin: 0 auto;
  }

  .hero-search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 15px 52px 15px 50px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text-primary);
    background: rgba(26, 26, 46, 0.8);
    border: 1px solid rgba(42, 42, 62, 0.8);
    border-radius: var(--radius-lg);
    outline: none;
    backdrop-filter: blur(8px);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
  }

  .hero-search-input::placeholder {
    color: var(--color-text-muted);
  }

  .hero-search-input:focus {
    border-color: var(--color-primary-light);
    box-shadow: 0 0 0 3px rgba(0, 165, 184, 0.15), var(--shadow-glow);
    background: rgba(26, 26, 46, 0.95);
  }

  .hero-search-kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: rgba(42, 42, 62, 0.6);
    border: 1px solid rgba(42, 42, 62, 0.8);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    pointer-events: none;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 56px 0 36px;
    }

    .hero-title {
      font-size: 1.8rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }
  }
</style>

---
import fs from 'node:fs';
import path from 'node:path';
import type { Plugin } from '../../types/plugin';
import { plugins } from '../../data/marketplace';
import { pluginSourceUrl } from '../../constants';
import { renderMarkdown } from '../../utils/markdown';
import { highlightCode } from '../../utils/highlight';
import Layout from '../../layouts/Layout.astro';
import GitHubAvatar from '../../components/GitHubAvatar.astro';

export function getStaticPaths() {
  return plugins.map((plugin) => ({
    params: { name: plugin.name },
    props: { plugin },
  }));
}

const { plugin } = Astro.props as { plugin: Plugin };

const pluginDir = path.resolve('..', plugin.source);

// --- README ---
let readmeHtml = '';
const readmePath = path.join(pluginDir, 'README.md');
if (fs.existsSync(readmePath)) {
  const md = fs.readFileSync(readmePath, 'utf-8');
  readmeHtml = await renderMarkdown(md);
}

// --- Discover plugin files ---

interface PluginFile {
  filename: string;
  html: string;
}

// Skills: skills/*/SKILL.md
const skillsDir = path.join(pluginDir, 'skills');
const skills: PluginFile[] = [];
if (fs.existsSync(skillsDir)) {
  const entries = fs.readdirSync(skillsDir, { withFileTypes: true });
  for (const entry of entries) {
    if (entry.isDirectory()) {
      const skillFile = path.join(skillsDir, entry.name, 'SKILL.md');
      if (fs.existsSync(skillFile)) {
        const filename = `skills/${entry.name}/SKILL.md`;
        skills.push({
          filename,
          html: await highlightCode(fs.readFileSync(skillFile, 'utf-8'), filename),
        });
      }
    }
  }
}

// Agents: agents/*.md
const agentsDir = path.join(pluginDir, 'agents');
const agents: PluginFile[] = [];
if (fs.existsSync(agentsDir)) {
  const entries = fs.readdirSync(agentsDir).filter((f) => f.endsWith('.md'));
  for (const file of entries) {
    const filename = `agents/${file}`;
    agents.push({
      filename,
      html: await highlightCode(fs.readFileSync(path.join(agentsDir, file), 'utf-8'), filename),
    });
  }
}

// Rules: rules/*.md
const rulesDir = path.join(pluginDir, 'rules');
const rules: PluginFile[] = [];
if (fs.existsSync(rulesDir)) {
  const entries = fs.readdirSync(rulesDir).filter((f) => f.endsWith('.md'));
  for (const file of entries) {
    const filename = `rules/${file}`;
    rules.push({
      filename,
      html: await highlightCode(fs.readFileSync(path.join(rulesDir, file), 'utf-8'), filename),
    });
  }
}

// Hooks: hooks/hooks.json + *.sh
const hooksDir = path.join(pluginDir, 'hooks');
let hooksJsonHtml = '';
const hookScripts: PluginFile[] = [];
if (fs.existsSync(hooksDir)) {
  const hooksJsonPath = path.join(hooksDir, 'hooks.json');
  if (fs.existsSync(hooksJsonPath)) {
    hooksJsonHtml = await highlightCode(fs.readFileSync(hooksJsonPath, 'utf-8'), 'hooks.json');
  }
  const shFiles = fs.readdirSync(hooksDir).filter((f) => f.endsWith('.sh'));
  for (const file of shFiles) {
    const filename = `hooks/${file}`;
    hookScripts.push({
      filename,
      html: await highlightCode(fs.readFileSync(path.join(hooksDir, file), 'utf-8'), filename),
    });
  }
}
const hasHooks = hooksJsonHtml || hookScripts.length > 0;

// Build tabs array
interface Tab {
  id: string;
  label: string;
}

const tabs: Tab[] = [{ id: 'readme', label: 'README' }];
if (skills.length > 0) tabs.push({ id: 'skills', label: 'Skills' });
if (agents.length > 0) tabs.push({ id: 'agents', label: 'Agents' });
if (rules.length > 0) tabs.push({ id: 'rules', label: 'Rules' });
if (hasHooks) tabs.push({ id: 'hooks', label: 'Hooks' });

const installCommand = `/plugin-install ${plugin.name}`;
const configSnippet = `{
  "plugins": {
    "install": ["${plugin.name}"]
  }
}`;
---

<Layout title={`${plugin.name} — ECA Plugin`} description={plugin.description}>
  <main class="detail-main">
    <div class="container">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to plugins
      </a>

      <div class="detail-layout">
        <div class="detail-content">
          <div class="detail-header">
            <span class="detail-icon">{plugin.icon}</span>
            <div>
              <h1 class="detail-name">{plugin.name}</h1>
              <p class="detail-description">{plugin.description}</p>
            </div>
          </div>

          <div class="detail-meta">
            <span class="detail-category">{plugin.category}</span>
            <div class="detail-tags">
              {plugin.tags.map(tag => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          </div>

          <div class="detail-author">
            <GitHubAvatar author={plugin.author} size={40} class="detail-author-avatar" />
            <a href={`https://github.com/${plugin.author}`} target="_blank" rel="noopener">{plugin.author}</a>
          </div>

          <div class="detail-tabs">
            <div class="detail-tabs-divider"></div>
            {tabs.length > 1 && (
              <div class="detail-tab-bar" role="tablist">
                {tabs.map((tab, i) => (
                  <button
                    role="tab"
                    class={`detail-tab ${i === 0 ? 'detail-tab--active' : ''}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`panel-${tab.id}`}
                    data-tab={tab.id}
                  >
                    {tab.label}
                  </button>
                ))}
              </div>
            )}

            {/* README Panel */}
            <div
              id="panel-readme"
              role="tabpanel"
              class="detail-tab-panel detail-tab-panel--active"
              data-panel="readme"
            >
              {readmeHtml && (
                <div class="detail-readme-content" set:html={readmeHtml} />
              )}
            </div>

            {/* Skills Panel */}
            {skills.length > 0 && (
              <div
                id="panel-skills"
                role="tabpanel"
                class="detail-tab-panel"
                data-panel="skills"
                hidden
              >
                {skills.map((skill) => (
                  <div class="detail-file-section">
                    <div class="detail-file-bar">
                      <code class="detail-file-name">{skill.filename}</code>
                    </div>
                    <div class="detail-code-block" set:html={skill.html} />
                  </div>
                ))}
              </div>
            )}

            {/* Agents Panel */}
            {agents.length > 0 && (
              <div
                id="panel-agents"
                role="tabpanel"
                class="detail-tab-panel"
                data-panel="agents"
                hidden
              >
                {agents.map((agent) => (
                  <div class="detail-file-section">
                    <div class="detail-file-bar">
                      <code class="detail-file-name">{agent.filename}</code>
                    </div>
                    <div class="detail-code-block" set:html={agent.html} />
                  </div>
                ))}
              </div>
            )}

            {/* Rules Panel */}
            {rules.length > 0 && (
              <div
                id="panel-rules"
                role="tabpanel"
                class="detail-tab-panel"
                data-panel="rules"
                hidden
              >
                {rules.map((rule) => (
                  <div class="detail-file-section">
                    <div class="detail-file-bar">
                      <code class="detail-file-name">{rule.filename}</code>
                    </div>
                    <div class="detail-code-block" set:html={rule.html} />
                  </div>
                ))}
              </div>
            )}

            {/* Hooks Panel */}
            {hasHooks && (
              <div
                id="panel-hooks"
                role="tabpanel"
                class="detail-tab-panel"
                data-panel="hooks"
                hidden
              >
                {hooksJsonHtml && (
                  <div class="detail-file-section">
                    <div class="detail-file-bar">
                      <code class="detail-file-name">hooks/hooks.json</code>
                    </div>
                    <div class="detail-code-block" set:html={hooksJsonHtml} />
                  </div>
                )}
                {hookScripts.map((script) => (
                  <div class="detail-file-section">
                    <div class="detail-file-bar">
                      <code class="detail-file-name">{script.filename}</code>
                    </div>
                    <div class="detail-code-block" set:html={script.html} />
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        <aside class="detail-sidebar">
          <div class="detail-install">
            <h3 class="detail-install-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Install
            </h3>

            <p class="detail-install-hint">Run this command in the ECA chat:</p>
            <div class="detail-command">
              <pre class="detail-command-code" id="command-code">{installCommand}</pre>
              <button class="detail-copy-btn" aria-label="Copy command to clipboard" data-copy="command">
                <svg class="detail-copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <svg class="detail-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>

            <details class="detail-manual">
              <summary class="detail-manual-toggle">
                <svg class="detail-manual-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
                Manual config.json setup
              </summary>
              <div class="detail-manual-content">
                <p class="detail-install-hint">Add to your <code>config.json</code> (global or project-level):</p>
                <div class="detail-config">
                  <pre class="detail-code" id="config-code">{configSnippet}</pre>
                  <button class="detail-copy-btn detail-copy-btn--sm" aria-label="Copy config to clipboard" data-copy="config">
                    <svg class="detail-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    <svg class="detail-check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            </details>
          </div>

          <div class="detail-info">
            <div class="detail-info-row">
              <span class="detail-info-label">Category</span>
              <span class="detail-info-value">{plugin.category}</span>
            </div>
            <div class="detail-info-row">
              <span class="detail-info-label">Author</span>
              <span class="detail-info-value">
                <GitHubAvatar author={plugin.author} size={32} class="detail-info-avatar" />
                {plugin.author}
              </span>
            </div>
            <div class="detail-info-row">
              <span class="detail-info-label">Source</span>
              <a href={pluginSourceUrl(plugin.source)} target="_blank" rel="noopener" class="detail-info-link">
                View on GitHub →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>

<script>
  const sources: Record<string, string> = {
    command: document.getElementById('command-code')?.textContent ?? '',
    config: document.getElementById('config-code')?.textContent ?? '',
  };

  document.querySelectorAll<HTMLButtonElement>('.detail-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.copy ?? '';
      const text = sources[key] ?? '';
      const copyIcon = btn.querySelector<SVGElement>('.detail-copy-icon')!;
      const checkIcon = btn.querySelector<SVGElement>('.detail-check-icon')!;

      try {
        await navigator.clipboard.writeText(text);
        copyIcon.setAttribute('hidden', '');
        checkIcon.removeAttribute('hidden');

        setTimeout(() => {
          copyIcon.removeAttribute('hidden');
          checkIcon.setAttribute('hidden', '');
        }, 2000);
      } catch {
        /* Fallback: select the text */
        const codeEl = document.getElementById(key === 'command' ? 'command-code' : 'config-code');
        if (codeEl) {
          const range = document.createRange();
          range.selectNodeContents(codeEl);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  });

  /* Tab switching */
  const tabBar = document.querySelector<HTMLDivElement>('.detail-tab-bar');
  if (tabBar) {
    const tabButtons = tabBar.querySelectorAll<HTMLButtonElement>('[role="tab"]');
    const panels = document.querySelectorAll<HTMLDivElement>('[role="tabpanel"]');

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.tab;

        tabButtons.forEach((b) => {
          b.classList.remove('detail-tab--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('detail-tab--active');
        btn.setAttribute('aria-selected', 'true');

        panels.forEach((panel) => {
          if (panel.dataset.panel === targetId) {
            panel.removeAttribute('hidden');
            panel.classList.add('detail-tab-panel--active');
          } else {
            panel.setAttribute('hidden', '');
            panel.classList.remove('detail-tab-panel--active');
          }
        });
      });
    });
  }
</script>

<style>
  .detail-main {
    min-height: calc(100vh - var(--header-height) - 100px);
    padding: 32px 0 80px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-primary-light);
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 40px;
    align-items: start;
    max-width: 1320px;
    margin: 0 auto;
  }

  .detail-content {
    min-width: 0;
  }

  .detail-header {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .detail-icon {
    font-size: 3rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .detail-name {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .detail-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .detail-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-blue);
    background: rgba(126, 200, 227, 0.1);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .detail-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .detail-tag {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-surface);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .detail-author {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 24px;
  }



  .detail-author a {
    color: var(--color-text-secondary);
  }

  .detail-author a:hover {
    color: var(--color-primary-light);
  }

  /* Tabs */
  .detail-tabs {
    margin-top: 8px;
  }

  .detail-tabs-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 0;
  }

  .detail-tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .detail-tab-bar::-webkit-scrollbar {
    display: none;
  }

  .detail-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 18px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-fast), border-color var(--transition-fast),
      background var(--transition-fast);
    font-family: var(--font-sans);
  }

  .detail-tab:hover {
    color: var(--color-text-secondary);
    background: rgba(0, 165, 184, 0.05);
  }

  .detail-tab--active {
    color: var(--color-primary-light);
    border-bottom-color: var(--color-primary-light);
  }

  .detail-tab--active:hover {
    color: var(--color-primary-light);
  }

  .detail-tab-panel {
    padding-top: 24px;
  }

  .detail-tab-panel[hidden] {
    display: none;
  }

  /* File section inside tabs */
  .detail-file-section {
    margin-bottom: 32px;
  }

  .detail-file-section:last-child {
    margin-bottom: 0;
  }

  .detail-file-bar {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .detail-file-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    background: none;
    padding: 0;
  }

  .detail-code-block :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    border: 1px solid var(--color-border);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    padding: 16px 20px;
    overflow-x: auto;
    line-height: 1.6;
    margin: 0;
  }

  .detail-code-block :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* README content */
  .detail-readme-content {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .detail-readme-content :global(h1) {
    display: none;
  }

  .detail-readme-content :global(h2) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 28px 0 12px;
  }

  .detail-readme-content :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 20px 0 8px;
  }

  .detail-readme-content :global(p) {
    margin: 0 0 14px;
  }

  .detail-readme-content :global(ul),
  .detail-readme-content :global(ol) {
    margin: 0 0 14px;
    padding-left: 24px;
  }

  .detail-readme-content :global(li) {
    margin-bottom: 6px;
  }

  .detail-readme-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-surface);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-accent-blue);
  }

  .detail-readme-content :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 16px;
    overflow-x: auto;
    margin: 0 0 14px;
    line-height: 1.5;
  }

  .detail-readme-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .detail-readme-content :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .detail-readme-content :global(a) {
    color: var(--color-primary-light);
  }

  .detail-readme-content :global(a:hover) {
    color: var(--color-primary-hover);
  }

  .detail-readme-content :global(blockquote) {
    border-left: 3px solid var(--color-border-active);
    margin: 0 0 14px;
    padding: 10px 16px;
    color: var(--color-text-muted);
    background: rgba(0, 165, 184, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .detail-readme-content :global(blockquote p) {
    margin: 0;
  }

  /* Sidebar */
  .detail-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 24px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .detail-install {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    border-top: 2px solid var(--color-primary);
  }

  .detail-install-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 14px;
  }

  .detail-install-title svg {
    color: var(--color-primary-light);
    flex-shrink: 0;
  }

  .detail-install-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  /* Primary command block */
  .detail-command {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary-light);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    margin-bottom: 16px;
  }

  .detail-command-code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary-hover);
    white-space: nowrap;
    overflow-x: auto;
    line-height: 1.4;
    margin: 0;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .detail-command-code::-webkit-scrollbar {
